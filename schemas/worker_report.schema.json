{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-pdf-vault.local/schemas/worker_report.schema.json",
  "title": "WorkerReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "worker_name",
    "paper_id",
    "stage_status",
    "started_at",
    "finished_at",
    "artifact_digest",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "report_id": {
      "type": "string",
      "pattern": "^report_[a-z0-9_]+$"
    },
    "worker_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "paper_id": {
      "type": "string",
      "readOnly": true,
      "pattern": "^paper_[a-z0-9_]+$"
    },
    "stage_status": {
      "enum": [
        "pending",
        "running",
        "complete",
        "failed",
        "quarantined"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
